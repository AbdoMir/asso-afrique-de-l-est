# Variables d'environnement — Association Afrique de l'Est et ses amis
# Copier ce fichier en .env.local et remplir les valeurs

# ─── SUPABASE ──────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://votre-projet.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=votre_anon_key
SUPABASE_SERVICE_ROLE_KEY=votre_service_role_key

# ─── STRIPE ────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Stripe — Price IDs des abonnements SEPA (à créer dans le dashboard Stripe)
STRIPE_PRICE_5_MONTHLY=price_...   # 5€/mois — Solidaire
STRIPE_PRICE_10_MONTHLY=price_...  # 10€/mois — Engagé
STRIPE_PRICE_20_MONTHLY=price_...  # 20€/mois — Soutien

# ─── PAYPAL (pas encore activé — structure prête, à remplir quand le compte ──
# PayPal Business sera créé) ─────────────────────────────────────────────────
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_MODE=sandbox  # sandbox | live
PAYPAL_WEBHOOK_ID=

# ─── COORDONNÉES BANCAIRES (virement — affichage informatif uniquement) ────
NEXT_PUBLIC_BANK_HOLDER=Association Afrique de l'Est et ses amis
NEXT_PUBLIC_BANK_IBAN=FRXX XXXX XXXX XXXX XXXX XXXX XXX
NEXT_PUBLIC_BANK_BIC=XXXXXXXX

# ─── HELLOASSO ─────────────────────────────────────────────────────────────
HELLOASSO_CLIENT_ID=votre_client_id
HELLOASSO_CLIENT_SECRET=votre_client_secret
NEXT_PUBLIC_HELLOASSO_ORG_SLUG=afrique-de-lest-et-ses-amis

# ─── RESEND ────────────────────────────────────────────────────────────────
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=contact@asso-aes.fr
RESEND_FROM_NAME=Association Afrique de l'Est et ses amis

# ─── PLAUSIBLE ANALYTICS ───────────────────────────────────────────────────
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=asso-aes.fr

# ─── APP ───────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_ASSOCIATION_NAME=Association Afrique de l'Est et ses amis
NEXT_PUBLIC_ASSOCIATION_EMAIL=asso.afrique.est.et.ses.amis@outlook.fr
NEXT_PUBLIC_ASSOCIATION_PHONE=06 05 67 59 11
NEXT_PUBLIC_ASSOCIATION_ADDRESS=45 Boulevard la Fontaine, 67200 Strasbourg
NEXT_PUBLIC_ASSOCIATION_SIRET=XXX XXX XXX XXXXX
NEXT_PUBLIC_RNA=WXXXXXXXXXX
